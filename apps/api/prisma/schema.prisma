generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum AuthSessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum SecurityEventSeverity {
  INFO
  WARNING
  CRITICAL
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionLifecycleStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  GRACE_PERIOD
  SUSPENDED
  CANCELED
}

enum BillingEventStatus {
  RECEIVED
  PROCESSED
  FAILED
  DUPLICATE
}

enum SystemRole {
  PLATFORM_SUPER_ADMIN
  HOTEL_OWNER
  PROPERTY_MANAGER
  RECEPTIONIST
  FINANCE_STAFF
  HOUSEKEEPING_STAFF
}

enum PropertyType {
  HOTEL
  APARTMENT
  VILLA
  HOSTEL
  GUESTHOUSE
  AIRBNB
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  DIRTY
  CLEANING
  READY
  MAINTENANCE
  OUT_OF_SERVICE
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
  BLOCKED
  MAINTENANCE
}

enum BookingSource {
  DIRECT
  WEBSITE
  AIRBNB
  BOOKING_COM
  EXPEDIA
  PHONE
  WALK_IN
  OTHER
}

enum PaymentMethod {
  CASH
  CARD
  CARD_AT_PROPERTY
  BANK_TRANSFER
  ONLINE
  MOCK
  OTHER
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  REFUNDED
  OVERDUE
}

enum PaymentType {
  DEPOSIT
  PARTIAL
  FULL
  REFUND
}

enum AutomationTrigger {
  RESERVATION_CREATED
  RESERVATION_CONFIRMED
  BEFORE_ARRIVAL
  ON_ARRIVAL_DAY
  AFTER_CHECK_IN
  BEFORE_CHECK_OUT
  AFTER_CHECK_OUT
  PAYMENT_RECEIVED
  PAYMENT_OVERDUE
  INVOICE_GENERATED
  RESERVATION_CANCELLED
  REVIEW_REQUEST
  CUSTOM_SCHEDULED
}

enum MessageChannel {
  EMAIL
  WHATSAPP
  SMS
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
}

enum WhatsAppProviderType {
  MOCK
  TWILIO
  META
}

enum WhatsAppConnectionStatus {
  DISCONNECTED
  PENDING
  CONNECTED
  FAILED
}

enum WhatsAppTemplateStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  DISABLED
}

enum WhatsAppMessageDirection {
  OUTBOUND
  INBOUND
}

enum WhatsAppMessageType {
  TEMPLATE
  SESSION
  INTERNAL_NOTIFICATION
}

enum WhatsAppMessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  DEAD_LETTER
}

enum ChannelProvider {
  AIRBNB
  BOOKING_COM
  EXPEDIA
  AGODA
  GOOGLE_HOTEL
  TRIPADVISOR
  DIRECT
}

enum HousekeepingStatus {
  TODO
  PENDING
  IN_PROGRESS
  DONE
  COMPLETED
  INSPECTED
  CANCELLED
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  CANCELLED
}

enum CalendarBlockType {
  BLOCKED
  MAINTENANCE
}

enum InventoryOutboxStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

enum InventoryOutboxEventType {
  RESERVATION_CREATED
  RESERVATION_UPDATED
  RESERVATION_CANCELLED
  ROOM_ASSIGNED
  ROOM_CHANGED
  CHECKED_IN
  CHECKED_OUT
  NO_SHOW
  CALENDAR_BLOCK_CREATED
  CALENDAR_BLOCK_UPDATED
  CALENDAR_BLOCK_DELETED
  ROOM_BLOCKED
  ROOM_UNBLOCKED
  ROOM_MAINTENANCE_STARTED
  ROOM_MAINTENANCE_ENDED
  RATE_UPDATED
  RESTRICTION_UPDATED
  INVENTORY_OVERRIDE_UPDATED
}

enum PaymentIdempotencyStatus {
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id                  String        @id @default(uuid())
  email               String        @unique
  passwordHash        String
  fullName            String
  phone               String?
  status              UserStatus    @default(ACTIVE)
  emailVerifiedAt     DateTime?
  refreshTokenHash    String?
  authSessions        AuthSession[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
  loginAttempts       LoginAttempt[]
  securityEvents      SecurityEvent[]
  sentInvitations     UserInvitation[] @relation("InvitationSender")
  acceptedInvitations UserInvitation[] @relation("InvitationAcceptedUser")
  companyMemberships  CompanyUser[]
  propertyAssignments PropertyUser[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?
}

model AuthSession {
  id               String            @id @default(uuid())
  userId           String
  tokenFamilyId    String
  refreshTokenHash String
  status           AuthSessionStatus @default(ACTIVE)
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime          @default(now())
  lastUsedAt       DateTime          @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?
  revokedReason    String?
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([tokenFamilyId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tokenHash])
  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tokenHash])
  @@index([userId, expiresAt])
}

model LoginAttempt {
  id        String   @id @default(uuid())
  email     String
  userId    String?
  success   Boolean
  ipAddress String?
  userAgent String?
  reason    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
  @@index([userId, createdAt])
}

model SecurityEvent {
  id        String                @id @default(uuid())
  userId    String?
  type      String
  severity  SecurityEventSeverity @default(INFO)
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime              @default(now())
  user      User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model UserInvitation {
  id             String    @id @default(uuid())
  companyId      String
  email          String
  roleId         String
  propertyId     String?
  tokenHash      String
  invitedById    String?
  acceptedUserId String?
  acceptedAt     DateTime?
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role           Role      @relation(fields: [roleId], references: [id])
  property       Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  invitedBy      User?     @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: SetNull)
  acceptedUser   User?     @relation("InvitationAcceptedUser", fields: [acceptedUserId], references: [id], onDelete: SetNull)

  @@unique([tokenHash])
  @@index([companyId, email])
  @@index([expiresAt])
}

model Company {
  id            String         @id @default(uuid())
  name          String
  legalName     String?
  email         String?
  phone         String?
  currency      String         @default("USD")
  timezone      String         @default("UTC")
  language      String         @default("en")
  users         CompanyUser[]
  properties    Property[]
  roles         Role[]
  guests        Guest[]
  reservations  Reservation[]
  reservationIdempotencyRecords ReservationIdempotencyRecord[]
  payments      Payment[]
  invoices      Invoice[]
  auditLogs     AuditLog[]
  notifications Notification[]
  moduleRecords ModuleRecord[]
  invitations   UserInvitation[]
  subscription  Subscription?
  billingCustomer BillingCustomer?
  subscriptionInvoices SubscriptionInvoice[]
  billingEvents BillingEvent[]
  usageRecords UsageRecord[]
  webhookEvents WebhookEvent[]
  whatsappConnections WhatsAppConnection[]
  whatsappRecipients WhatsAppRecipient[]
  whatsappTemplates WhatsAppTemplate[]
  whatsappMessages WhatsAppMessage[]
  whatsappWebhookEvents WhatsAppWebhookEvent[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
}

model CompanyUser {
  id        String   @id @default(uuid())
  companyId String
  userId    String
  roleId    String
  isOwner   Boolean  @default(false)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, userId])
  @@index([userId])
}

model Role {
  id                 String           @id @default(uuid())
  companyId          String?
  name               String
  systemRole         SystemRole?
  company            Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  permissions        RolePermission[]
  companyUsers       CompanyUser[]
  propertyUsers      PropertyUser[]
  invitations        UserInvitation[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([companyId, name])
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  description String
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Property {
  id                  String               @id @default(uuid())
  companyId           String
  name                String
  slug                String               @unique
  description         String?
  address             String
  country             String
  city                String
  phone               String?
  email               String?
  currency            String
  timezone            String
  language            String               @default("en")
  propertyType        PropertyType
  checkInTime         String               @default("15:00")
  checkOutTime        String               @default("11:00")
  cancellationPolicy  String?
  taxRate             Decimal              @default(0)
  logoUrl             String?
  imageUrls           String[]             @default([])
  bookingSettings     Json?
  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users               PropertyUser[]
  roomTypes           RoomType[]
  rooms               Room[]
  reservations        Reservation[]
  automations         Automation[]
  messageTemplates    MessageTemplate[]
  channelConnections  ChannelConnection[]
  housekeepingTasks   HousekeepingTask[]
  maintenanceIssues   MaintenanceIssue[]
  calendarBlocks      CalendarBlock[]
  bookingPageSetting  BookingPageSetting?
  invitations         UserInvitation[]
  whatsappMessages    WhatsAppMessage[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?

  @@index([companyId])
  @@index([country, city])
}

model PropertyUser {
  id         String   @id @default(uuid())
  propertyId String
  userId     String
  roleId     String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([propertyId, userId])
  @@index([userId])
}

model RoomType {
  id            String        @id @default(uuid())
  companyId     String
  propertyId    String
  name          String
  description   String?
  capacity      Int
  adultsLimit   Int
  childrenLimit Int           @default(0)
  basePrice     Decimal
  weekendPrice  Decimal?
  seasonalPrice Decimal?
  amenities     RoomAmenity[]
  rooms         Room[]
  property      Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  @@index([companyId, propertyId])
}

model Room {
  id            String            @id @default(uuid())
  companyId     String
  propertyId    String
  roomTypeId    String
  name          String
  floor         String?
  status        RoomStatus        @default(AVAILABLE)
  cleaningStatus RoomStatus       @default(READY)
  maintenanceStatus RoomStatus    @default(AVAILABLE)
  imageUrls     String[]          @default([])
  property      Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomType      RoomType          @relation(fields: [roomTypeId], references: [id])
  reservations  ReservationRoom[]
  oldRoomChanges ReservationRoomChange[] @relation("OldRoomChanges")
  newRoomChanges ReservationRoomChange[] @relation("NewRoomChanges")
  housekeepingTasks HousekeepingTask[]
  maintenanceIssues MaintenanceIssue[]
  calendarBlocks CalendarBlock[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?

  @@unique([propertyId, name])
  @@index([companyId, propertyId, roomTypeId])
  @@index([propertyId, status, cleaningStatus, maintenanceStatus])
}

model Amenity {
  id        String        @id @default(uuid())
  name      String        @unique
  icon      String?
  roomTypes RoomAmenity[]
}

model RoomAmenity {
  roomTypeId String
  amenityId  String
  roomType   RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  amenity    Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([roomTypeId, amenityId])
}

model Guest {
  id                  String             @id @default(uuid())
  companyId           String
  fullName            String
  email               String?
  phone               String?
  whatsappConsent     Boolean            @default(false)
  whatsappConsentAt   DateTime?
  whatsappConsentSource String?
  whatsappOptedOut    Boolean            @default(false)
  preferredCommunicationChannel String?
  country             String?
  address             String?
  identificationDoc   String?
  dateOfBirth         DateTime?
  notes               String?
  preferences         Json?
  totalStays          Int                @default(0)
  totalSpending       Decimal            @default(0)
  outstandingBalance  Decimal            @default(0)
  company             Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reservations        Reservation[]
  reservationGuests   ReservationGuest[]
  whatsappMessages    WhatsAppMessage[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?

  @@index([companyId, email])
  @@index([companyId, phone])
}

model Reservation {
  id              String             @id @default(uuid())
  companyId       String
  propertyId      String
  guestId         String
  reservationCode String             @unique
  status          ReservationStatus  @default(PENDING)
  bookingSource   BookingSource      @default(DIRECT)
  checkInDate     DateTime
  checkOutDate    DateTime
  adults          Int
  children        Int                @default(0)
  subtotal        Decimal
  discount        Decimal            @default(0)
  tax             Decimal            @default(0)
  totalAmount     Decimal
  paymentStatus   PaymentStatus      @default(UNPAID)
  internalNotes   String?
  history         Json?
  checkedInAt     DateTime?
  checkedOutAt    DateTime?
  noShowAt        DateTime?
  checkedInByUserId String?
  checkedOutByUserId String?
  noShowByUserId  String?
  company         Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  property        Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  guest           Guest              @relation(fields: [guestId], references: [id])
  guests          ReservationGuest[]
  rooms           ReservationRoom[]
  extras          ReservationExtra[]
  payments        Payment[]
  invoices        Invoice[]
  messageLogs     MessageLog[]
  channelReservations ChannelReservation[]
  whatsappMessages WhatsAppMessage[]
  idempotencyRecords ReservationIdempotencyRecord[]
  roomChanges     ReservationRoomChange[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?

  @@index([companyId, propertyId, checkInDate, checkOutDate])
  @@index([propertyId, status, checkInDate, checkOutDate])
  @@index([guestId])
}

model CalendarBlock {
  id                 String            @id @default(uuid())
  companyId          String
  propertyId         String
  roomId             String
  type               CalendarBlockType
  startDate          DateTime
  endDate            DateTime
  reason             String
  maintenanceIssueId String?
  createdByUserId    String
  deletedAt          DateTime?
  property           Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  room               Room              @relation(fields: [roomId], references: [id], onDelete: Cascade)
  maintenanceIssue   MaintenanceIssue? @relation(fields: [maintenanceIssueId], references: [id], onDelete: SetNull)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([companyId, propertyId, roomId, startDate, endDate])
  @@index([propertyId, type, startDate, endDate])
}

model InventoryOutboxEvent {
  id              String                    @id @default(uuid())
  companyId       String
  propertyId      String
  roomId          String?
  roomTypeId      String?
  reservationId   String?
  calendarBlockId String?
  eventType       InventoryOutboxEventType
  payload         Json
  status          InventoryOutboxStatus     @default(PENDING)
  attempts        Int                       @default(0)
  availableAt     DateTime                  @default(now())
  processedAt     DateTime?
  lastError       String?
  idempotencyKey  String
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@unique([companyId, idempotencyKey])
  @@index([status, availableAt])
  @@index([companyId, propertyId, status, createdAt])
}

model PaymentIdempotencyRecord {
  id              String                    @id @default(uuid())
  companyId       String
  reservationId   String
  idempotencyKey  String
  requestHash     String
  paymentId       String?
  responsePayload Json?
  status          PaymentIdempotencyStatus  @default(PROCESSING)
  expiresAt       DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@unique([companyId, idempotencyKey])
  @@index([reservationId, status])
  @@index([expiresAt])
}

model PropertyOperationalPolicy {
  id                                  String   @id @default(uuid())
  propertyId                          String   @unique
  timezone                            String   @default("UTC")
  standardCheckInTime                 String   @default("15:00")
  standardCheckOutTime                String   @default("11:00")
  allowEarlyCheckIn                   Boolean  @default(false)
  earliestEarlyCheckInTime            String?
  allowLateCheckOut                   Boolean  @default(false)
  latestLateCheckOutTime              String?
  requireCleanRoomForCheckIn          Boolean  @default(true)
  requireGuestDetailsForCheckIn       Boolean  @default(true)
  requireIdentificationConfirmation   Boolean  @default(true)
  requireDepositBeforeCheckIn         Boolean  @default(false)
  minimumDepositType                  String   @default("NONE")
  minimumDepositValue                 Decimal  @default(0)
  requireFullPaymentBeforeCheckout    Boolean  @default(false)
  allowForceCheckout                  Boolean  @default(true)
  autoGenerateInvoiceOnCheckout       Boolean  @default(true)
  createHousekeepingTaskOnCheckout    Boolean  @default(true)
  noShowCutoffTime                    String   @default("23:59")
  createdAt                           DateTime @default(now())
  updatedAt                           DateTime @updatedAt
}

model ReservationRoomChange {
  id              String      @id @default(uuid())
  companyId       String
  propertyId      String
  reservationId   String
  oldRoomId       String?
  newRoomId       String
  reason          String?
  changedByUserId String
  changedAt       DateTime    @default(now())
  reservation     Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  oldRoom         Room?       @relation("OldRoomChanges", fields: [oldRoomId], references: [id])
  newRoom         Room        @relation("NewRoomChanges", fields: [newRoomId], references: [id])

  @@index([companyId, propertyId, reservationId])
  @@index([oldRoomId])
  @@index([newRoomId])
}

model ReservationIdempotencyRecord {
  id              String      @id @default(uuid())
  companyId       String
  idempotencyKey  String
  requestHash     String
  reservationId   String?
  status          String
  response        Json?
  errorMessage    String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  company         Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reservation     Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  @@unique([companyId, idempotencyKey])
  @@index([companyId, status, createdAt])
}

model ReservationGuest {
  reservationId String
  guestId       String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  guest         Guest       @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@id([reservationId, guestId])
}

model ReservationRoom {
  id            String      @id @default(uuid())
  reservationId String
  roomId        String
  pricePerNight Decimal
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  room          Room        @relation(fields: [roomId], references: [id])

  @@unique([reservationId, roomId])
  @@index([roomId])
}

model ReservationExtra {
  id            String      @id @default(uuid())
  reservationId String
  name          String
  quantity      Int         @default(1)
  unitPrice     Decimal
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String        @id @default(uuid())
  companyId     String
  reservationId String
  method        PaymentMethod
  type          PaymentType   @default(PARTIAL)
  status        PaymentStatus @default(PARTIALLY_PAID)
  amount        Decimal
  currency      String
  provider      String        @default("mock")
  providerRef   String?
  idempotencyKey String?
  notes         String?
  recordedByUserId String?
  paidAt        DateTime?
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reservation   Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([companyId, idempotencyKey])
  @@index([companyId, reservationId])
}

model Invoice {
  id              String        @id @default(uuid())
  companyId       String
  reservationId   String
  invoiceNumber   String
  status          PaymentStatus @default(UNPAID)
  subtotal        Decimal
  tax             Decimal
  discount        Decimal       @default(0)
  total           Decimal
  paidAmount      Decimal       @default(0)
  remainingAmount Decimal
  currency        String        @default("USD")
  pdfPath         String?
  generatedByUserId String?
  dueDate         DateTime?
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reservation     Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  items           InvoiceItem[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([companyId, invoiceNumber])
  @@index([companyId, reservationId])
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal
  taxRate     Decimal @default(0)
  total       Decimal
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Automation {
  id          String            @id @default(uuid())
  companyId   String
  propertyId  String
  trigger     AutomationTrigger
  channel     MessageChannel
  templateId  String
  delayMinutes Int              @default(0)
  enabled     Boolean           @default(true)
  language    String            @default("en")
  property    Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  template    MessageTemplate   @relation(fields: [templateId], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([companyId, propertyId, trigger])
}

model MessageTemplate {
  id          String          @id @default(uuid())
  companyId   String
  propertyId  String
  name        String
  channel     MessageChannel
  language    String          @default("en")
  subject     String?
  body        String
  property    Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  automations Automation[]
  messageLogs MessageLog[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([propertyId, name, language, channel])
}

model MessageLog {
  id             String          @id @default(uuid())
  companyId      String
  reservationId  String?
  templateId     String?
  channel        MessageChannel
  status         MessageStatus   @default(QUEUED)
  recipient      String
  provider       String          @default("mock")
  sentAt         DateTime?
  deliveredAt    DateTime?
  errorDetails   String?
  reservation    Reservation?    @relation(fields: [reservationId], references: [id])
  template       MessageTemplate? @relation(fields: [templateId], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([companyId, reservationId])
}

model ChannelConnection {
  id          String          @id @default(uuid())
  companyId   String
  propertyId  String
  provider    ChannelProvider
  displayName String
  enabled     Boolean         @default(false)
  credentials Json?
  settings    Json?
  property    Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reservations ChannelReservation[]
  logs        IntegrationLog[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([propertyId, provider])
}

model ChannelReservation {
  id                  String            @id @default(uuid())
  companyId           String
  reservationId        String?
  channelConnectionId  String
  externalReservationId String
  payload              Json
  reservation          Reservation?      @relation(fields: [reservationId], references: [id])
  channelConnection    ChannelConnection @relation(fields: [channelConnectionId], references: [id], onDelete: Cascade)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@unique([channelConnectionId, externalReservationId])
}

model IntegrationLog {
  id                  String            @id @default(uuid())
  companyId            String
  channelConnectionId  String
  action              String
  status              String
  message             String?
  payload             Json?
  retryCount          Int               @default(0)
  channelConnection   ChannelConnection @relation(fields: [channelConnectionId], references: [id], onDelete: Cascade)
  createdAt           DateTime          @default(now())

  @@index([companyId, channelConnectionId])
}

model HousekeepingTask {
  id          String             @id @default(uuid())
  companyId   String
  propertyId  String
  roomId      String
  reservationId String?
  title       String
  status      HousekeepingStatus @default(TODO)
  priority    Int                @default(2)
  assignedTo  String?
  assignedToUserId String?
  notes       String?
  checklist   Json?
  dueDate     DateTime?
  dueAt       DateTime?
  completedAt DateTime?
  createdByUserId String?
  property    Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  room        Room               @relation(fields: [roomId], references: [id])
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([companyId, propertyId, status])
}

model MaintenanceIssue {
  id          String            @id @default(uuid())
  companyId   String
  propertyId  String
  roomId      String?
  title       String
  description String
  status      MaintenanceStatus @default(OPEN)
  category    String?
  priority    Int               @default(2)
  assignedToUserId String?
  estimatedCost Decimal?
  actualCost  Decimal?
  blocksRoomFromSale Boolean     @default(false)
  notes       String?
  property    Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  room        Room?             @relation(fields: [roomId], references: [id])
  calendarBlocks CalendarBlock[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  companyId String
  userId    String?
  type      String
  title     String
  body      String
  readAt    DateTime?
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([companyId, userId, readAt])
}

model AuditLog {
  id             String   @id @default(uuid())
  companyId      String
  userId         String?
  action         String
  entityType     String
  entityId       String
  previousValues Json?
  newValues      Json?
  ipAddress      String?
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user           User?    @relation(fields: [userId], references: [id])
  createdAt      DateTime @default(now())

  @@index([companyId, entityType, entityId])
}

model Subscription {
  id        String   @id @default(uuid())
  companyId String   @unique
  plan      String
  status    String
  seats     Int      @default(3)
  planId    String?
  billingCustomerId String?
  interval  BillingInterval @default(MONTHLY)
  lifecycleStatus SubscriptionLifecycleStatus @default(TRIALING)
  currentPeriodStart DateTime?
  currentPeriodEnd DateTime?
  trialEndsAt DateTime?
  cancelAtPeriodEnd Boolean @default(false)
  canceledAt DateTime?
  graceEndsAt DateTime?
  suspendedAt DateTime?
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscriptionPlan SubscriptionPlan? @relation(fields: [planId], references: [id])
  billingCustomer BillingCustomer? @relation(fields: [billingCustomerId], references: [id])
  invoices  SubscriptionInvoice[]
  usageRecords UsageRecord[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SubscriptionPlan {
  id                 String   @id @default(uuid())
  code               String   @unique
  name               String
  description        String?
  monthlyPriceCents  Int
  yearlyPriceCents   Int
  currency           String   @default("USD")
  maxProperties      Int
  maxRooms           Int
  maxStaffUsers      Int
  basicReports       Boolean  @default(true)
  advancedReports    Boolean  @default(false)
  premiumAutomation  Boolean  @default(false)
  bookingEngine      Boolean  @default(false)
  channelManager     Boolean  @default(false)
  active             Boolean  @default(true)
  subscriptions      Subscription[]
  entitlements       FeatureEntitlement[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model FeatureEntitlement {
  id        String   @id @default(uuid())
  planId    String
  feature   String
  enabled   Boolean  @default(false)
  limit     Int?
  plan      SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([planId, feature])
}

model BillingCustomer {
  id                  String   @id @default(uuid())
  companyId           String   @unique
  provider            String   @default("mock")
  providerCustomerId  String?
  email               String?
  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscriptions       Subscription[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model SubscriptionInvoice {
  id               String   @id @default(uuid())
  companyId        String
  subscriptionId   String
  provider         String   @default("mock")
  providerInvoiceId String?
  invoiceNumber    String
  status           String
  currency         String   @default("USD")
  subtotalCents    Int
  taxCents         Int      @default(0)
  totalCents       Int
  paidAt           DateTime?
  dueAt            DateTime?
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscription     Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([companyId, invoiceNumber])
  @@index([subscriptionId, createdAt])
}

model BillingEvent {
  id              String             @id @default(uuid())
  companyId       String
  provider        String             @default("mock")
  providerEventId String?
  type            String
  status          BillingEventStatus @default(RECEIVED)
  payload         Json
  processedAt     DateTime?
  errorMessage    String?
  company         Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt       DateTime           @default(now())

  @@unique([provider, providerEventId])
  @@index([companyId, createdAt])
}

model UsageRecord {
  id             String   @id @default(uuid())
  companyId      String
  subscriptionId String?
  metric         String
  quantity       Int
  periodStart    DateTime
  periodEnd      DateTime
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())

  @@index([companyId, metric, periodStart, periodEnd])
}

model WebhookEvent {
  id              String             @id @default(uuid())
  companyId       String?
  provider        String
  providerEventId String
  signature       String?
  status          BillingEventStatus @default(RECEIVED)
  payload         Json
  processedAt     DateTime?
  errorMessage    String?
  company         Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdAt       DateTime           @default(now())

  @@unique([provider, providerEventId])
  @@index([companyId, createdAt])
}

model WhatsAppConnection {
  id                    String                    @id @default(uuid())
  companyId             String
  provider              WhatsAppProviderType
  businessAccountId     String?
  phoneNumberId         String?
  senderPhoneNumber     String
  encryptedAccessToken  String?
  encryptedRefreshToken String?
  status                WhatsAppConnectionStatus @default(PENDING)
  verifiedAt            DateTime?
  company               Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@unique([companyId, provider, senderPhoneNumber])
  @@index([senderPhoneNumber, status])
  @@index([companyId, status])
}

model WhatsAppRecipient {
  id                String   @id @default(uuid())
  companyId         String
  name              String
  phoneNumber       String
  notificationTypes String[] @default([])
  isActive          Boolean  @default(true)
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([companyId, phoneNumber])
  @@index([companyId, isActive])
}

model WhatsAppTemplate {
  id                 String                @id @default(uuid())
  companyId          String
  providerTemplateId String?
  name               String
  language           String
  category           String
  eventType          String
  bodyPreview        String
  status             WhatsAppTemplateStatus @default(DRAFT)
  isActive           Boolean               @default(true)
  company            Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  messages           WhatsAppMessage[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@unique([companyId, name, language])
  @@index([companyId, eventType, isActive])
}

model WhatsAppMessage {
  id                String                   @id @default(uuid())
  companyId         String
  propertyId        String?
  reservationId     String?
  guestId           String?
  direction         WhatsAppMessageDirection
  recipientPhone    String
  senderPhone       String?
  messageType       WhatsAppMessageType
  templateId        String?
  body              String
  providerMessageId String?
  idempotencyKey    String
  status            WhatsAppMessageStatus    @default(QUEUED)
  errorCode         String?
  errorMessage      String?
  queuedAt          DateTime                 @default(now())
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  failedAt          DateTime?
  company           Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  property          Property?                @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  reservation       Reservation?             @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  guest             Guest?                   @relation(fields: [guestId], references: [id], onDelete: SetNull)
  template          WhatsAppTemplate?        @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@unique([companyId, idempotencyKey])
  @@unique([providerMessageId])
  @@index([companyId, status, queuedAt])
  @@index([companyId, recipientPhone, createdAt])
  @@index([reservationId])
  @@index([guestId])
}

model WhatsAppWebhookEvent {
  id              String              @id @default(uuid())
  provider        WhatsAppProviderType
  providerEventId String
  companyId       String?
  payloadHash     String
  processedAt     DateTime?
  status          BillingEventStatus  @default(RECEIVED)
  errorMessage    String?
  company         Company?            @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdAt       DateTime            @default(now())

  @@unique([provider, providerEventId])
  @@index([companyId, createdAt])
  @@index([payloadHash])
}

model BookingPageSetting {
  id                String   @id @default(uuid())
  companyId         String
  propertyId        String   @unique
  enabled           Boolean  @default(true)
  heroTitle         String
  heroSubtitle      String?
  brandColor        String   @default("#2563eb")
  gallery           String[] @default([])
  customDomain      String?
  wifiPassword      String?
  doorCode          String?
  property          Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ModuleRecord {
  id        String   @id @default(uuid())
  companyId String
  moduleKey String
  name      String
  status    String
  owner     String
  amount    String
  date      DateTime?
  channel   String
  notes     String?
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([companyId, moduleKey, status])
  @@index([companyId, moduleKey, name])
}
