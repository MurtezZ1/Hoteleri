{
  "name": "odeoniflow-pms",
  "version": "0.1.0",
  "private": true,
  "description": "OdeoniFlow PMS multi-tenant hotel and property management SaaS monorepo.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "npm --workspace @odeoniflow/api run db:generate",
    "db:migrate": "npm --workspace @odeoniflow/api run db:migrate",
    "db:seed": "npm --workspace @odeoniflow/api run db:seed",
    "db:e2e:reset": "npm --workspace @odeoniflow/api run db:e2e:reset",
    "db:e2e:seed": "npm --workspace @odeoniflow/api run db:e2e:seed",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "build": "npm run build --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/swagger": "^11.4.6",
    "@nestjs/testing": "^11.1.28",
    "@playwright/test": "^1.61.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "rxjs": "^7.8.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "engines": {
    "node": ">=20.18.0"
  }
}
